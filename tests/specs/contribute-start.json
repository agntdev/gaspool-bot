[
  {
    "name": "contribute:start shows destination address",
    "steps": [
      {
        "send": { "callback": "contribute:start" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "No destination address configured yet. Ask the pool owner to set one via Admin."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "contribute:cancel cancels the flow",
    "steps": [
      {
        "send": { "callback": "contribute:start" },
        "expect": [{ "method": "answerCallbackQuery" }]
      },
      {
        "send": { "callback": "contribute:cancel" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText", "payload": { "text": "Contribution cancelled." } }
        ]
      }
    ]
  }
]
